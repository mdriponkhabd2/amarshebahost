rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * AMARSHEBAHOST SECURITY RULES CONFIGURATION
     * 
     * Core Philosophy:
     * This ruleset implements a CMS-style security model for a web hosting service. 
     * During the prototyping phase, we allow public read/write access to content 
     * collections to enable immediate use of the Admin Panel without complex auth setup.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // In a production app, you would use:
      // return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
      return true; // Relaxed for prototyping
    }

    // --- Collection Rules ---

    match /roles_admin/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create, update, delete: if false; 
    }

    match /features/{featureId} {
      allow get, list: if true;
      allow create, update, delete: if true; 
    }

    match /pricingPlans/{planId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }

    match /testimonials/{testimonialId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }

    match /navigationLinks/{linkId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }

    match /websiteContentBlocks/{blockId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }
  }
}